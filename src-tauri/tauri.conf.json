{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevTrees",
  "version": "0.9.0",
  "identifier": "com.xbox.devtrees",
  "build": {
    "beforeDevCommand": "yarn dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build:web",
    "frontendDist": "../dist-web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DevTrees",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyMjZCMUEzREYzN0QwN0YKUldSLzBEZmZvN0VtTXJESUZZSU5OTC8vczlDbFBjZ3hUMGpNR2ZsQ2hJcHd2dXR6cUNxaWdMTGoK",
      "endpoints": [
        "https://github.com/cottonstartiet/DevTrees/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
